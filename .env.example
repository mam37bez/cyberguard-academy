# Скопируйте в .env.local для разработки или задайте в Vercel → Settings → Environment Variables

# Почта через Resend (обязательно для форм «Контакт» и «Запись»)
RESEND_API_KEY=

# Серверная проверка Cloudflare Turnstile (должен соответствовать виджету на страницах)
TURNSTILE_SECRET_KEY=

# Опционально: аналитика
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_YM_ID=
