# Скопируйте в .env.local для разработки или задайте в Vercel → Settings → Environment Variables

# Почта через Resend (обязательно для форм «Контакт» и «Запись»)
RESEND_API_KEY=

# Серверная проверка Cloudflare Turnstile (должен соответствовать виджету на страницах)
TURNSTILE_SECRET_KEY=

# Google Safe Browsing API (серверный ключ; только в Vercel / .env.local, без NEXT_PUBLIC_)
# Включите Safe Browsing API в Google Cloud → APIs & Services, создайте API key с ограничением по API.
GOOGLE_SAFE_BROWSING_API_KEY=

# Опционально: аналитика (только публичные ключи; без кавычек в Vercel)
# Google Analytics 4 — полный Measurement ID, например G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=
# Яндекс.Метрика — только номер счётчика (цифры), например 108475655; не используйте префикс id=
NEXT_PUBLIC_YM_ID=
